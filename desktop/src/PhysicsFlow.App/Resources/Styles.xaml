<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:PhysicsFlow.App.Converters">

    <!-- ── Converters ────────────────────────────────────────────────────── -->
    <conv:ActiveColorConverter x:Key="ActiveColorConverter"/>
    <!-- Both keys used across different views -->
    <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

    <!-- ── Card style: rounded dark panel ────────────────────────────────── -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background"    Value="#1E2A3A"/>
        <Setter Property="CornerRadius"  Value="8"/>
        <Setter Property="Padding"       Value="16"/>
        <Setter Property="BorderBrush"   Value="#2A3A4A"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ── Stat card style: slightly more prominent card ─────────────────── -->
    <Style x:Key="StatCardStyle" TargetType="Border">
        <Setter Property="Background"    Value="#162030"/>
        <Setter Property="CornerRadius"  Value="8"/>
        <Setter Property="Padding"       Value="16,12"/>
        <Setter Property="BorderBrush"   Value="#2A3A4A"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ── Nav button: full-width flat sidebar button ────────────────────── -->
    <Style x:Key="NavButtonStyle" TargetType="Button">
        <Setter Property="Background"         Value="Transparent"/>
        <Setter Property="Foreground"         Value="#C8C8E0"/>
        <Setter Property="BorderThickness"    Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Cursor"             Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#2A3A50"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1A2A40"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Accent button: blue call-to-action ────────────────────────────── -->
    <Style x:Key="AccentButtonStyle" TargetType="Button">
        <Setter Property="Background"         Value="#1565C0"/>
        <Setter Property="Foreground"         Value="White"/>
        <Setter Property="BorderThickness"    Value="0"/>
        <Setter Property="Cursor"             Value="Hand"/>
        <Setter Property="FontWeight"         Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1976D2"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0D47A1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Danger button: red stop/delete action ─────────────────────────── -->
    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="Background"         Value="#C62828"/>
        <Setter Property="Foreground"         Value="White"/>
        <Setter Property="BorderThickness"    Value="0"/>
        <Setter Property="Cursor"             Value="Hand"/>
        <Setter Property="FontWeight"         Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#E53935"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#B71C1C"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Quick action button: card-like tile ───────────────────────────── -->
    <Style x:Key="QuickActionButtonStyle" TargetType="Button">
        <Setter Property="Background"               Value="#162030"/>
        <Setter Property="Foreground"               Value="#E0E0F0"/>
        <Setter Property="BorderBrush"              Value="#2A3A4A"/>
        <Setter Property="BorderThickness"          Value="1"/>
        <Setter Property="Padding"                  Value="12,16"/>
        <Setter Property="Cursor"                   Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"   Value="#1E3050"/>
                            <Setter TargetName="Bd" Property="BorderBrush"  Value="#3A5A7A"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0E2040"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Icon button: small flat transparent icon-only button ─────────── -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Padding"         Value="4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#55FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Chip button: pill-shaped quick-action tag ─────────────────────── -->
    <Style x:Key="ChipButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="#1A2A40"/>
        <Setter Property="Foreground"      Value="#99BBDD"/>
        <Setter Property="BorderBrush"     Value="#2A3A50"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"  Value="#1E3A5A"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#3A5A7A"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0E2A4A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Floating action button: circular icon button ─────────────────── -->
    <Style x:Key="FloatingActionButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="#1565C0"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="18"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1976D2"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#0D47A1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
