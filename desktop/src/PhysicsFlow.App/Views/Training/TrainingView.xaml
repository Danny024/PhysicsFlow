<UserControl x:Class="PhysicsFlow.App.Views.Training.TrainingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:oxy="http://oxyplot.org/wpf">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header + controls -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="PINO Surrogate Training" FontSize="26" FontWeight="Light"/>
                <TextBlock Text="Train the Physics-Informed Neural Operator on OPM FLOW simulation data."
                           FontSize="13" Foreground="{DynamicResource MahApps.Brushes.Gray5}"
                           Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Content="▶  Start Training" Margin="0,0,8,0"
                        Command="{Binding StartTrainingCommand}"
                        IsEnabled="{Binding CanStart}"
                        Style="{StaticResource AccentButtonStyle}"
                        Width="140" Height="36"/>
                <Button Content="⏹  Stop" Margin="0,0,8,0"
                        Command="{Binding StopTrainingCommand}"
                        IsEnabled="{Binding IsTraining}"
                        Style="{StaticResource DangerButtonStyle}"
                        Width="80" Height="36"/>
                <Button Content="💾  Save Model"
                        Command="{Binding SaveModelCommand}"
                        IsEnabled="{Binding CanSaveModel}"
                        Width="120" Height="36"/>
            </StackPanel>
        </Grid>

        <!-- Config + Progress cards -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Training config -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Configuration" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <TextBlock Text="Mode" FontSize="11" Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                    <ComboBox ItemsSource="{Binding Modes}" SelectedItem="{Binding SelectedMode}"
                              Margin="0,2,0,10"/>

                    <TextBlock Text="Epochs" FontSize="11" Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                    <mah:NumericUpDown Value="{Binding Epochs}" Minimum="1" Maximum="10000"
                                       Interval="50" Margin="0,2,0,10"/>

                    <TextBlock Text="Learning Rate" FontSize="11" Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                    <mah:NumericUpDown Value="{Binding LearningRate}" Minimum="0.000001" Maximum="0.01"
                                       Interval="0.0001" StringFormat="0.######" Margin="0,2,0,10"/>

                    <TextBlock Text="Training Samples" FontSize="11" Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                    <mah:NumericUpDown Value="{Binding TrainingSamples}" Minimum="10" Maximum="10000"
                                       Interval="10" Margin="0,2,0,10"/>

                    <TextBlock Text="PDE Loss Weight" FontSize="11" Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                    <Slider Value="{Binding PdeLossWeight}" Minimum="0" Maximum="10"
                            TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="0,2,0,4"/>
                    <TextBlock Text="{Binding PdeLossWeight, StringFormat={}{0:F2}}" FontSize="10"
                               HorizontalAlignment="Right"/>

                    <CheckBox Content="Use GPU" IsChecked="{Binding UseGpu}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Live progress -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Training Progress" FontSize="14"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <!-- Progress bar -->
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ProgressBar Value="{Binding ProgressPct}" Maximum="100"
                                     Height="8" Background="{DynamicResource MahApps.Brushes.Gray3}"/>
                        <TextBlock Grid.Column="1" Margin="12,0,0,0"
                                   Text="{Binding ProgressText}" FontSize="12"/>
                    </Grid>

                    <!-- Stats row -->
                    <UniformGrid Grid.Row="2" Columns="5">
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Total Loss" FontSize="10"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                            <TextBlock Text="{Binding TotalLoss, StringFormat={}{0:F5}}"
                                       FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="PDE Loss" FontSize="10"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                            <TextBlock Text="{Binding PdeLoss, StringFormat={}{0:F5}}"
                                       FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Data Loss" FontSize="10"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                            <TextBlock Text="{Binding DataLoss, StringFormat={}{0:F5}}"
                                       FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="GPU Util" FontSize="10"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                            <TextBlock Text="{Binding GpuUtil, StringFormat={}{0:F0}%}"
                                       FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="ETA" FontSize="10"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                            <TextBlock Text="{Binding Eta}" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Loss curves chart -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Loss Curves (live)" FontSize="14"
                           FontWeight="SemiBold" Margin="0,0,0,12"/>
                <oxy:PlotView Grid.Row="1" Model="{Binding LossCurveModel}" MinHeight="300"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
