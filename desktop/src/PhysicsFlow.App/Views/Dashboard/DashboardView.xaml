<UserControl x:Class="PhysicsFlow.App.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:oxy="http://oxyplot.org/wpf">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Page header ─────────────────────────────────────────── -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Dashboard" FontSize="26" FontWeight="Light"
                           Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                <TextBlock Text="{Binding ProjectSummaryLine}" FontSize="13"
                           Foreground="{DynamicResource MahApps.Brushes.Gray5}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- ── Stat cards row ──────────────────────────────────────── -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,20">

                <!-- Wells card -->
                <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <iconPacks:PackIconMaterial Kind="WaterPump" Width="20" Height="20"
                                                        Foreground="{DynamicResource MahApps.Brushes.Accent}"
                                                        Margin="0,0,8,0"/>
                            <TextBlock Text="Wells" FontSize="12"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding WellCount}" FontSize="32" FontWeight="Bold"/>
                        <TextBlock Text="{Binding WellBreakdown}" FontSize="11"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                    </StackPanel>
                </Border>

                <!-- Grid card -->
                <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <iconPacks:PackIconMaterial Kind="Grid" Width="20" Height="20"
                                                        Foreground="#E67E22" Margin="0,0,8,0"/>
                            <TextBlock Text="Grid" FontSize="12"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding GridDimensions}" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="{Binding ActiveCells}" FontSize="11"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                    </StackPanel>
                </Border>

                <!-- Surrogate status card -->
                <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <iconPacks:PackIconMaterial Kind="Brain" Width="20" Height="20"
                                                        Foreground="{Binding SurrogateStatusColor}"
                                                        Margin="0,0,8,0"/>
                            <TextBlock Text="PINO Surrogate" FontSize="12"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding SurrogateStatus}" FontSize="20" FontWeight="Bold"
                                   Foreground="{Binding SurrogateStatusColor}"/>
                        <TextBlock Text="{Binding SurrogateDetail}" FontSize="11"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                    </StackPanel>
                </Border>

                <!-- HM status card -->
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <iconPacks:PackIconMaterial Kind="ChartTimelineVariant" Width="20" Height="20"
                                                        Foreground="{Binding HMStatusColor}"
                                                        Margin="0,0,8,0"/>
                            <TextBlock Text="History Match" FontSize="12"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding HMStatus}" FontSize="20" FontWeight="Bold"
                                   Foreground="{Binding HMStatusColor}"/>
                        <TextBlock Text="{Binding HMDetail}" FontSize="11"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── Quick actions ───────────────────────────────────────── -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Quick Actions" FontSize="14"
                               FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <UniformGrid Grid.Row="1" Columns="4">
                        <Button Style="{StaticResource QuickActionButtonStyle}"
                                Command="{Binding NewProjectCommand}" Margin="0,0,8,0">
                            <StackPanel>
                                <iconPacks:PackIconMaterial Kind="FolderPlus" Width="24" Height="24"
                                                            HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="New Project" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource QuickActionButtonStyle}"
                                Command="{Binding OpenProjectCommand}" Margin="0,0,8,0">
                            <StackPanel>
                                <iconPacks:PackIconMaterial Kind="FolderOpen" Width="24" Height="24"
                                                            HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="Open Project" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource QuickActionButtonStyle}"
                                Command="{Binding StartTrainingCommand}" Margin="0,0,8,0"
                                IsEnabled="{Binding CanStartTraining}">
                            <StackPanel>
                                <iconPacks:PackIconMaterial Kind="PlayCircle" Width="24" Height="24"
                                                            HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="Train Surrogate" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource QuickActionButtonStyle}"
                                Command="{Binding StartHMCommand}"
                                IsEnabled="{Binding CanStartHM}">
                            <StackPanel>
                                <iconPacks:PackIconMaterial Kind="TuneVariant" Width="24" Height="24"
                                                            HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="History Match" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </UniformGrid>
                </Grid>
            </Border>

            <!-- ── Recent projects + Well map ─────────────────────────── -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent projects list -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,16,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Recent Projects" FontSize="14"
                                   FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <ListBox Grid.Row="1" ItemsSource="{Binding RecentProjects}"
                                 SelectedItem="{Binding SelectedRecentProject}"
                                 Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" Cursor="Hand">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FieldName}"
                                                       FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="{Binding LastModified}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource MahApps.Brushes.Gray5}"/>
                                            <TextBlock Text="{Binding StatusLine}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Well map (2D areal view) placeholder -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Well Map" FontSize="14"
                                   FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <!-- OxyPlot scatter plot of well locations -->
                        <oxy:PlotView Grid.Row="1"
                                      Model="{Binding WellMapModel}"
                                      MinHeight="300"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
