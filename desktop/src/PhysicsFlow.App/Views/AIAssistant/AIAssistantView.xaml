<UserControl x:Class="PhysicsFlow.App.Views.AIAssistant.AIAssistantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:PhysicsFlow.App.Views.AIAssistant">

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Model selector -->
            <RowDefinition Height="Auto"/>
            <!-- Quick action chips -->
            <RowDefinition Height="Auto"/>
            <!-- Message list -->
            <RowDefinition Height="*"/>
            <!-- Typing indicator -->
            <RowDefinition Height="Auto"/>
            <!-- Input area -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{DynamicResource MahApps.Brushes.Accent}"
                Padding="12,8">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="Brain" Width="18" Height="18"
                                               Foreground="White" VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                    <TextBlock Text="AI Reservoir Assistant" FontWeight="SemiBold"
                               FontSize="13" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" Style="{StaticResource IconButtonStyle}"
                        Command="{Binding ClearHistoryCommand}"
                        ToolTip="Clear conversation">
                    <iconPacks:PackIconMaterial Kind="DeleteSweep" Width="14" Height="14"
                                               Foreground="White"/>
                </Button>
            </Grid>
        </Border>

        <!-- ── Model selector ────────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="8,6,8,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Model:" VerticalAlignment="Center" FontSize="11"
                       Foreground="{DynamicResource MahApps.Brushes.Gray5}" Margin="0,0,6,0"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableModels}"
                      SelectedItem="{Binding SelectedModel}"
                      FontSize="11" Height="24"/>
            <Ellipse Grid.Column="2" Width="8" Height="8" Margin="6,0,0,0"
                     Fill="{Binding OllamaStatusColor}" ToolTip="{Binding OllamaStatusText}"/>
        </Grid>

        <!-- ── Quick action chips ─────────────────────────────────────── -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled" Margin="6,4,6,4">
            <ItemsControl ItemsSource="{Binding QuickActions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Label}"
                                Command="{Binding DataContext.SendQuickActionCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding Prompt}"
                                Style="{StaticResource ChipButtonStyle}"
                                Margin="3,0" Padding="8,4" FontSize="10"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Message list ───────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="3" x:Name="MessageScroller"
                      VerticalScrollBarVisibility="Auto"
                      Padding="4,0">
            <ItemsControl ItemsSource="{Binding Messages}" x:Name="MessageList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Dynamic template: user vs assistant messages -->
                        <local:ChatMessageView Margin="4,3"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ── Typing indicator ───────────────────────────────────────── -->
        <Border Grid.Row="4" Visibility="{Binding IsTyping, Converter={StaticResource BoolToVisConverter}}"
                Margin="12,2,12,2">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Fill="{DynamicResource MahApps.Brushes.Accent}"
                         Margin="0,0,3,0">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="Dot1Scale" ScaleX="1" ScaleY="1" CenterX="4" CenterY="4"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="Dot1Scale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     From="1" To="0.4" Duration="0:0:0.4"
                                                     AutoReverse="True"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <TextBlock Text="AI is thinking..." FontSize="10" FontStyle="Italic"
                           Foreground="{DynamicResource MahApps.Brushes.Gray5}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Input area ─────────────────────────────────────────────── -->
        <Border Grid.Row="5" BorderBrush="{DynamicResource MahApps.Brushes.Gray3}"
                BorderThickness="0,1,0,0" Padding="8,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                    Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                    mah:TextBoxHelper.Watermark="Ask about your reservoir..."
                    mah:TextBoxHelper.ClearTextButton="True"
                    AcceptsReturn="False"
                    FontSize="12"
                    MinHeight="36"
                    MaxHeight="80"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto"
                    Padding="8,6">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SendMessageCommand}"/>
                        <KeyBinding Key="Return" Modifiers="Shift"
                                    Command="{Binding NewLineCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <Button Grid.Column="1" Margin="6,0,0,0"
                        Command="{Binding SendMessageCommand}"
                        IsEnabled="{Binding CanSend}"
                        Width="36" Height="36"
                        Style="{StaticResource AccentButtonStyle}"
                        ToolTip="Send (Enter)">
                    <iconPacks:PackIconMaterial Kind="Send" Width="14" Height="14"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
