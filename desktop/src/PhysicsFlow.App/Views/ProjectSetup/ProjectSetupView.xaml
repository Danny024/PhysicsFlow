<UserControl x:Class="PhysicsFlow.App.Views.ProjectSetup.ProjectSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="900"
             Background="#0A1628">

    <UserControl.Resources>
        <Style x:Key="StepIndicatorActive" TargetType="Border">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Background" Value="#00D4FF"/>
        </Style>
        <Style x:Key="StepIndicatorDone" TargetType="Border">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Background" Value="#00CC66"/>
        </Style>
        <Style x:Key="StepIndicatorPending" TargetType="Border">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Background" Value="#1A3050"/>
            <Setter Property="BorderBrush" Value="#2A4060"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#8899AA"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#0F2040"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A4060"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title -->
            <RowDefinition Height="Auto"/>   <!-- Step indicator -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Navigation buttons -->
        </Grid.RowDefinitions>

        <!-- ── Title ──────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#0F2040" Padding="24,16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="NEW PROJECT SETUP"
                           FontFamily="Segoe UI Semibold" FontSize="20" Foreground="White"/>
                <TextBlock Text="Configure your reservoir model in 5 steps"
                           FontFamily="Segoe UI" FontSize="12" Foreground="#8899AA" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── Step indicator bar ─────────────────────────────────────────── -->
        <Border Grid.Row="1" Padding="24,0,24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Step connectors (lines between circles) -->
                <Rectangle Grid.Column="0" Grid.ColumnSpan="4"
                           Height="2" Fill="#1A3050" VerticalAlignment="Center" Margin="18,0"/>

                <!-- Step 1: Grid -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <Border Style="{StaticResource StepIndicatorActive}"
                            HorizontalAlignment="Center"
                            Visibility="{Binding Step1Active, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="1" Foreground="#0A1628" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Style="{StaticResource StepIndicatorDone}"
                            HorizontalAlignment="Center"
                            Visibility="{Binding Step1Done, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="✓" Foreground="White" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Style="{StaticResource StepIndicatorPending}"
                            HorizontalAlignment="Center"
                            Visibility="{Binding Step1Pending, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="1" Foreground="#8899AA" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Grid" HorizontalAlignment="Center"
                               FontSize="11" Foreground="#8899AA" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Step 2: Wells -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <Border Style="{StaticResource StepIndicatorActive}"
                            HorizontalAlignment="Center"
                            Visibility="{Binding Step2Active, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="2" Foreground="#0A1628" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Style="{StaticResource StepIndicatorPending}"
                            HorizontalAlignment="Center"
                            Visibility="{Binding Step2Pending, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="2" Foreground="#8899AA" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Wells" HorizontalAlignment="Center"
                               FontSize="11" Foreground="#8899AA" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Step 3: PVT -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <Border Style="{StaticResource StepIndicatorActive}"
                            HorizontalAlignment="Center"
                            Visibility="{Binding Step3Active, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="3" Foreground="#0A1628" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Style="{StaticResource StepIndicatorPending}"
                            HorizontalAlignment="Center"
                            Visibility="{Binding Step3Pending, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="3" Foreground="#8899AA" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="PVT" HorizontalAlignment="Center"
                               FontSize="11" Foreground="#8899AA" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Step 4: Schedule -->
                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <Border Style="{StaticResource StepIndicatorActive}"
                            HorizontalAlignment="Center"
                            Visibility="{Binding Step4Active, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="4" Foreground="#0A1628" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Style="{StaticResource StepIndicatorPending}"
                            HorizontalAlignment="Center"
                            Visibility="{Binding Step4Pending, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="4" Foreground="#8899AA" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Schedule" HorizontalAlignment="Center"
                               FontSize="11" Foreground="#8899AA" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Step 5: Review -->
                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                    <Border Style="{StaticResource StepIndicatorActive}"
                            HorizontalAlignment="Center"
                            Visibility="{Binding Step5Active, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="5" Foreground="#0A1628" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border Style="{StaticResource StepIndicatorPending}"
                            HorizontalAlignment="Center"
                            Visibility="{Binding Step5Pending, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="5" Foreground="#8899AA" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Review" HorizontalAlignment="Center"
                               FontSize="11" Foreground="#8899AA" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Step content (ContentControl routes by CurrentStep) ────────── -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,0">
            <ContentControl Content="{Binding}">
                <ContentControl.Resources>

                    <!-- STEP 1: GRID ─────────────────────────────────────────── -->
                    <DataTemplate x:Key="Step1Template">
                        <StackPanel>
                            <TextBlock Text="1 — Grid Configuration"
                                       FontFamily="Segoe UI Semibold" FontSize="16"
                                       Foreground="White" Margin="0,0,0,16"/>

                            <!-- Import Eclipse deck or manual entry -->
                            <Border Background="#0F2040" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Import from Eclipse Deck (optional)"
                                               Style="{StaticResource SectionLabelStyle}" FontSize="13" Foreground="#CCDDEE"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Style="{StaticResource InputStyle}"
                                                 Text="{Binding EclipseDeckPath}"
                                                 IsReadOnly="True" Margin="0,0,8,0"/>
                                        <Button Grid.Column="1"
                                                Command="{Binding BrowseEclipseDeckCommand}"
                                                Content="Browse…"
                                                Background="#1A3050" Foreground="#00D4FF"
                                                BorderBrush="#2A4060" BorderThickness="1"
                                                Padding="12,8" Cursor="Hand"/>
                                    </Grid>
                                    <TextBlock Text="Supported: .DATA (keyword deck). Grid dimensions, PORO, PERMX, ACTNUM will be read automatically."
                                               Foreground="#8899AA" FontSize="11" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Manual dimensions -->
                            <Border Background="#0F2040" CornerRadius="8" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Grid Dimensions" Style="{StaticResource SectionLabelStyle}"
                                               FontSize="13" Foreground="#CCDDEE" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Nx (I direction)" Style="{StaticResource SectionLabelStyle}"/>
                                            <mah:NumericUpDown Value="{Binding GridNx}" Minimum="1" Maximum="500"
                                                                Background="#0A1628" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                            <TextBlock Text="Ny (J direction)" Style="{StaticResource SectionLabelStyle}"/>
                                            <mah:NumericUpDown Value="{Binding GridNy}" Minimum="1" Maximum="500"
                                                                Background="#0A1628" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Nz (K layers)" Style="{StaticResource SectionLabelStyle}"/>
                                            <mah:NumericUpDown Value="{Binding GridNz}" Minimum="1" Maximum="200"
                                                                Background="#0A1628" Foreground="White"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="dx (m)" Style="{StaticResource SectionLabelStyle}"/>
                                            <mah:NumericUpDown Value="{Binding GridDx}" Minimum="1" Maximum="10000"
                                                                Background="#0A1628" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                            <TextBlock Text="dy (m)" Style="{StaticResource SectionLabelStyle}"/>
                                            <mah:NumericUpDown Value="{Binding GridDy}" Minimum="1" Maximum="10000"
                                                                Background="#0A1628" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                                            <TextBlock Text="dz (m)" Style="{StaticResource SectionLabelStyle}"/>
                                            <mah:NumericUpDown Value="{Binding GridDz}" Minimum="0.1" Maximum="1000"
                                                                Background="#0A1628" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3">
                                            <TextBlock Text="Depth (m TVDSS)" Style="{StaticResource SectionLabelStyle}"/>
                                            <mah:NumericUpDown Value="{Binding GridDepth}" Minimum="100" Maximum="10000"
                                                                Background="#0A1628" Foreground="White"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Margin="0,12,0,0" Foreground="#8899AA" FontSize="11">
                                        <Run Text="Total cells: "/>
                                        <Run Text="{Binding TotalCells, StringFormat={}{0:N0}}" Foreground="#00D4FF"/>
                                        <Run Text="  |  Active cells: "/>
                                        <Run Text="{Binding ActiveCells, StringFormat={}{0:N0}}" Foreground="#00CC66"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DataTemplate>

                    <!-- STEP 2: WELLS ────────────────────────────────────────── -->
                    <DataTemplate x:Key="Step2Template">
                        <StackPanel>
                            <TextBlock Text="2 — Well Configuration"
                                       FontFamily="Segoe UI Semibold" FontSize="16"
                                       Foreground="White" Margin="0,0,0,16"/>
                            <Border Background="#0F2040" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Import from Eclipse COMPDAT / WELSPECS"
                                               Style="{StaticResource SectionLabelStyle}" FontSize="13" Foreground="#CCDDEE"/>
                                    <Button Command="{Binding ImportCompdatCommand}"
                                            Content="Import COMPDAT from .DATA file"
                                            Background="#1A3050" Foreground="#00D4FF"
                                            BorderBrush="#2A4060" BorderThickness="1"
                                            Padding="14,8" Cursor="Hand" HorizontalAlignment="Left"
                                            Margin="0,8,0,8"/>
                                    <Button Command="{Binding LoadNorneDefaultsCommand}"
                                            Content="Load Norne defaults (22P + 9WI + 4GI)"
                                            Background="#1A3050" Foreground="#00CC66"
                                            BorderBrush="#2A4060" BorderThickness="1"
                                            Padding="14,8" Cursor="Hand" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#0F2040" CornerRadius="8" Padding="16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Wells"
                                                   Style="{StaticResource SectionLabelStyle}"
                                                   FontSize="13" Foreground="#CCDDEE" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Command="{Binding AddWellCommand}"
                                                Content="+ Add Well"
                                                Background="#00D4FF" Foreground="#0A1628"
                                                FontWeight="Bold" Padding="12,6" Cursor="Hand"
                                                BorderThickness="0"/>
                                    </Grid>
                                    <DataGrid ItemsSource="{Binding Wells}"
                                              AutoGenerateColumns="False"
                                              Background="#0A1628" Foreground="White"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="None"
                                              BorderThickness="0"
                                              MaxHeight="280"
                                              CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="120"/>
                                            <DataGridTextColumn Header="Type" Binding="{Binding WellType}" Width="100"/>
                                            <DataGridTextColumn Header="Perforations" Binding="{Binding PerfCount}" Width="100"/>
                                            <DataGridTextColumn Header="BHP Limit (bar)" Binding="{Binding BhpLimitBar, StringFormat={}{0:F1}}" Width="120"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock Margin="0,8,0,0" Foreground="#8899AA" FontSize="11">
                                        <Run Text="{Binding WellCount}" Foreground="#00D4FF"/>
                                        <Run Text=" wells configured  |  "/>
                                        <Run Text="{Binding ProducerCount}" Foreground="#00CC66"/>
                                        <Run Text=" producers  |  "/>
                                        <Run Text="{Binding InjectorCount}" Foreground="#4488FF"/>
                                        <Run Text=" injectors"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DataTemplate>

                    <!-- STEP 3: PVT ──────────────────────────────────────────── -->
                    <DataTemplate x:Key="Step3Template">
                        <StackPanel>
                            <TextBlock Text="3 — PVT Configuration"
                                       FontFamily="Segoe UI Semibold" FontSize="16"
                                       Foreground="White" Margin="0,0,0,16"/>
                            <Border Background="#0F2040" CornerRadius="8" Padding="16">
                                <StackPanel>
                                    <Button Command="{Binding LoadNornePvtCommand}"
                                            Content="Load Norne PVT Defaults"
                                            Background="#1A3050" Foreground="#00CC66"
                                            BorderBrush="#2A4060" BorderThickness="1"
                                            Padding="14,8" Cursor="Hand" HorizontalAlignment="Left"
                                            Margin="0,0,0,16"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                                            <TextBlock Text="Initial Pressure (bar)" Style="{StaticResource SectionLabelStyle}"/>
                                            <mah:NumericUpDown Value="{Binding PvtInitialPressure}"
                                                                Minimum="10" Maximum="1000"
                                                                Background="#0A1628" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                                            <TextBlock Text="Temperature (°C)" Style="{StaticResource SectionLabelStyle}"/>
                                            <mah:NumericUpDown Value="{Binding PvtTemperature}"
                                                                Minimum="20" Maximum="200"
                                                                Background="#0A1628" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,12">
                                            <TextBlock Text="API Gravity" Style="{StaticResource SectionLabelStyle}"/>
                                            <mah:NumericUpDown Value="{Binding PvtApiGravity}"
                                                                Minimum="10" Maximum="70"
                                                                Background="#0A1628" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                                            <TextBlock Text="Gas Gravity (air=1)" Style="{StaticResource SectionLabelStyle}"/>
                                            <mah:NumericUpDown Value="{Binding PvtGasGravity}"
                                                                Minimum="0.5" Maximum="2.0"
                                                                Interval="0.01"
                                                                Background="#0A1628" Foreground="White"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,0">
                                            <TextBlock Text="Connate Water Saturation (Swi)" Style="{StaticResource SectionLabelStyle}"/>
                                            <mah:NumericUpDown Value="{Binding PvtSwi}"
                                                                Minimum="0.0" Maximum="0.5"
                                                                Interval="0.01"
                                                                Background="#0A1628" Foreground="White"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DataTemplate>

                    <!-- STEP 4: SCHEDULE ─────────────────────────────────────── -->
                    <DataTemplate x:Key="Step4Template">
                        <StackPanel>
                            <TextBlock Text="4 — Production Schedule"
                                       FontFamily="Segoe UI Semibold" FontSize="16"
                                       Foreground="White" Margin="0,0,0,16"/>
                            <Border Background="#0F2040" CornerRadius="8" Padding="16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Schedule Entries"
                                                   Style="{StaticResource SectionLabelStyle}"
                                                   FontSize="13" Foreground="#CCDDEE" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Command="{Binding AddScheduleEntryCommand}"
                                                Content="+ Add Period"
                                                Background="#00D4FF" Foreground="#0A1628"
                                                FontWeight="Bold" Padding="12,6" Cursor="Hand"
                                                BorderThickness="0"/>
                                    </Grid>
                                    <DataGrid ItemsSource="{Binding ScheduleEntries}"
                                              AutoGenerateColumns="False"
                                              Background="#0A1628" Foreground="White"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="None"
                                              BorderThickness="0"
                                              MaxHeight="280"
                                              CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Well" Binding="{Binding WellName}" Width="100"/>
                                            <DataGridTextColumn Header="Start" Binding="{Binding StartDate}" Width="100"/>
                                            <DataGridTextColumn Header="End" Binding="{Binding EndDate}" Width="100"/>
                                            <DataGridTextColumn Header="Control" Binding="{Binding ControlMode}" Width="80"/>
                                            <DataGridTextColumn Header="Target" Binding="{Binding TargetValue, StringFormat={}{0:N0}}" Width="80"/>
                                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="70"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DataTemplate>

                    <!-- STEP 5: REVIEW ───────────────────────────────────────── -->
                    <DataTemplate x:Key="Step5Template">
                        <StackPanel>
                            <TextBlock Text="5 — Review &amp; Save"
                                       FontFamily="Segoe UI Semibold" FontSize="16"
                                       Foreground="White" Margin="0,0,0,16"/>
                            <Border Background="#0F2040" CornerRadius="8" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="{Binding ReviewSummary}"
                                               FontFamily="Consolas" FontSize="13"
                                               Foreground="#CCDDEE" xml:space="preserve"/>
                                    <Separator Background="#1A3050" Margin="0,16"/>
                                    <StackPanel>
                                        <TextBlock Text="Project Name" Style="{StaticResource SectionLabelStyle}"/>
                                        <TextBox Style="{StaticResource InputStyle}"
                                                 Text="{Binding ProjectName}" Margin="0,0,0,12"/>
                                        <TextBlock Text="Save Location" Style="{StaticResource SectionLabelStyle}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Style="{StaticResource InputStyle}"
                                                     Text="{Binding SavePath}" IsReadOnly="True" Margin="0,0,8,0"/>
                                            <Button Grid.Column="1"
                                                    Command="{Binding BrowseSavePathCommand}"
                                                    Content="Browse…"
                                                    Background="#1A3050" Foreground="#00D4FF"
                                                    BorderBrush="#2A4060" BorderThickness="1"
                                                    Padding="12,8" Cursor="Hand"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ContentControl.Resources>

                <!-- Step routing via style/trigger -->
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="ContentTemplate" Value="{StaticResource Step1Template}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                <Setter Property="ContentTemplate" Value="{StaticResource Step2Template}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                                <Setter Property="ContentTemplate" Value="{StaticResource Step3Template}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="4">
                                <Setter Property="ContentTemplate" Value="{StaticResource Step4Template}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="5">
                                <Setter Property="ContentTemplate" Value="{StaticResource Step5Template}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </ScrollViewer>

        <!-- ── Navigation buttons ─────────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#0D1B2E" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Validation error -->
                <TextBlock Grid.Column="1" Text="{Binding ValidationMessage}"
                           Foreground="#FF6B6B" FontSize="12"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="0"
                        Command="{Binding BackCommand}"
                        Content="← Back"
                        Style="{StaticResource NavButtonStyle}"
                        Background="#1A3050" Foreground="#8899AA"
                        BorderBrush="#2A4060" BorderThickness="1"
                        Margin="0,0,12,0"
                        IsEnabled="{Binding CanGoBack}"/>

                <Button Grid.Column="2"
                        Command="{Binding CancelCommand}"
                        Content="Cancel"
                        Style="{StaticResource NavButtonStyle}"
                        Background="Transparent" Foreground="#8899AA"
                        BorderBrush="#2A4060" BorderThickness="1"
                        Margin="0,0,12,0"/>

                <!-- Next / Save button -->
                <Button Grid.Column="3"
                        Command="{Binding NextCommand}"
                        Content="{Binding NextButtonLabel}"
                        Style="{StaticResource NavButtonStyle}"
                        Background="#00D4FF" Foreground="#0A1628"
                        FontWeight="Bold"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
