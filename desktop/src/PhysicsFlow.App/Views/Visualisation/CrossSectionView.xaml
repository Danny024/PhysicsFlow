<UserControl x:Class="PhysicsFlow.App.Views.Visualisation.CrossSectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100"
             Background="#0D1B2E">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="#0A1628"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ToolbarLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8899AA"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="12,0,4,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="SliceImage" TargetType="Image">
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="RenderOptions.BitmapScalingMode" Value="NearestNeighbor"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Controls -->
            <RowDefinition Height="*"/>     <!-- Slice tabs -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Row 0: Header ═══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource CardPanel}" Margin="12,12,12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="2D Cross-Section Viewer"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="#4488FF"/>
                    <TextBlock Text="I / J / K plane slices with property colour mapping"
                               FontSize="11" Foreground="#8899AA" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Command="{Binding ExportImageCommand}"
                        VerticalAlignment="Center"
                        Padding="12,6" Margin="4,0"
                        Background="Transparent" BorderBrush="#1E3A5F"
                        Foreground="#4488FF">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ImageExport" Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock Text="Export Image"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ Row 1: Controls ══════════════════════════════════════════════ -->
        <Border Grid.Row="1" Style="{StaticResource CardPanel}" Margin="12,4,12,0">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <TextBlock Text="Property:" Style="{StaticResource ToolbarLabel}" Margin="0,0,4,0"/>
                <ComboBox ItemsSource="{Binding PropertyOptions}"
                          SelectedItem="{Binding SelectedProperty}"
                          Width="160" VerticalAlignment="Center"
                          Background="#112233" Foreground="White" BorderBrush="#1E3A5F"/>

                <TextBlock Text="Colourmap:" Style="{StaticResource ToolbarLabel}"/>
                <ComboBox ItemsSource="{Binding ColourmapOptions}"
                          SelectedItem="{Binding SelectedColourmap}"
                          Width="100" VerticalAlignment="Center"
                          Background="#112233" Foreground="White" BorderBrush="#1E3A5F"/>

                <TextBlock Text="Slice:" Style="{StaticResource ToolbarLabel}"/>
                <Slider Value="{Binding SliceIndex}"
                        Minimum="0" Maximum="111"
                        Width="180" VerticalAlignment="Center"
                        Foreground="#4488FF"
                        TickFrequency="1" IsSnapToTickEnabled="True"/>
                <TextBlock Text="{Binding SliceIndexLabel}"
                           Foreground="#CCDDEE" FontSize="11" FontFamily="Consolas"
                           VerticalAlignment="Center" Margin="6,0,0,0" MinWidth="50"/>

                <CheckBox Content="Show wells"
                          IsChecked="{Binding ShowWellOverlay}"
                          Foreground="#AABBCC" VerticalAlignment="Center"
                          Margin="16,0,0,0"/>
            </WrapPanel>
        </Border>

        <!-- ═══ Row 2: Slice tabs ════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="12,4,12,4" Background="#0A1628" CornerRadius="6">
            <TabControl Background="Transparent" BorderThickness="0"
                        Padding="0">

                <!-- I-Plane (YZ) -->
                <TabItem Header="I-Plane (YZ)" Foreground="#AABBCC">
                    <Grid Background="#060E1A">
                        <Image Source="{Binding IPlaneImage}"
                               Style="{StaticResource SliceImage}"
                               Margin="8"/>
                        <Canvas Visibility="{Binding ShowWellOverlay,
                                    Converter={StaticResource BoolToVisConverter}}"
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <!-- Well overlay markers (drawn by ViewModel-driven ItemsControl in future iteration) -->
                        </Canvas>
                        <TextBlock Text="I-Plane: fix I, show J-K cross-section"
                                   Foreground="#334455" FontSize="10"
                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                   Margin="10,0,0,10"/>
                    </Grid>
                </TabItem>

                <!-- J-Plane (XZ) -->
                <TabItem Header="J-Plane (XZ)" Foreground="#AABBCC">
                    <Grid Background="#060E1A">
                        <Image Source="{Binding JPlaneImage}"
                               Style="{StaticResource SliceImage}"
                               Margin="8"/>
                        <Canvas Visibility="{Binding ShowWellOverlay,
                                    Converter={StaticResource BoolToVisConverter}}"
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        <TextBlock Text="J-Plane: fix J, show I-K cross-section"
                                   Foreground="#334455" FontSize="10"
                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                   Margin="10,0,0,10"/>
                    </Grid>
                </TabItem>

                <!-- K-Plane (XY) -->
                <TabItem Header="K-Plane (XY)" Foreground="#AABBCC">
                    <Grid Background="#060E1A">
                        <Image Source="{Binding KPlaneImage}"
                               Style="{StaticResource SliceImage}"
                               Margin="8"/>
                        <Canvas Visibility="{Binding ShowWellOverlay,
                                    Converter={StaticResource BoolToVisConverter}}"
                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        <TextBlock Text="K-Plane: fix K (layer), show I-J map view"
                                   Foreground="#334455" FontSize="10"
                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                   Margin="10,0,0,10"/>
                    </Grid>
                </TabItem>

            </TabControl>
        </Border>

        <!-- ═══ Row 3: Status bar ════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#060E1A" Padding="12,6" Margin="12,0,12,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#8899AA" FontSize="11" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
