<Window x:Class="PhysicsFlow.App.Views.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Settings — PhysicsFlow"
        Width="560" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#12192A"
        Foreground="White">

    <Window.Resources>
        <Style x:Key="GroupLabel" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Foreground"   Value="#8899BB"/>
            <Setter Property="Margin"       Value="0,0,0,4"/>
        </Style>
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background"        Value="#0F2040"/>
            <Setter Property="Foreground"        Value="White"/>
            <Setter Property="BorderBrush"       Value="#2A4060"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="8,6"/>
            <Setter Property="FontFamily"        Value="Consolas"/>
            <Setter Property="FontSize"          Value="12"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="#00D4FF"/>
            <Setter Property="Margin"       Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- title -->
            <RowDefinition Height="*"/>     <!-- sections -->
            <RowDefinition Height="Auto"/>  <!-- buttons -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Settings" FontSize="22" FontWeight="Light" Foreground="White"/>
            <TextBlock Text="Configure engine connection, AI model, and default paths."
                       FontSize="12" Foreground="#667799" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Sections -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ── Engine ────────────────────────────────────────── -->
                <Border Background="#0F1E35" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Engine Connection" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="gRPC Address" Style="{StaticResource GroupLabel}"/>
                        <TextBox Style="{StaticResource FieldBox}"
                                 Text="{Binding EngineGrpcAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="REST API Address" Style="{StaticResource GroupLabel}"/>
                        <TextBox Style="{StaticResource FieldBox}"
                                 Text="{Binding EngineRestAddress, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- ── AI Assistant ───────────────────────────────────── -->
                <Border Background="#0F1E35" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="AI Assistant (Ollama)" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Ollama Base URL" Style="{StaticResource GroupLabel}"/>
                        <TextBox Style="{StaticResource FieldBox}"
                                 Text="{Binding OllamaBaseUrl, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,10"/>

                        <TextBlock Text="Default Model" Style="{StaticResource GroupLabel}"/>
                        <TextBox Style="{StaticResource FieldBox}"
                                 Text="{Binding OllamaModel, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="e.g. phi3:mini, llama3.1, mistral"
                                   FontSize="10" Foreground="#445566" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- ── Projects ──────────────────────────────────────── -->
                <Border Background="#0F1E35" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Projects" Style="{StaticResource SectionHeader}"/>

                        <TextBlock Text="Default Project Directory" Style="{StaticResource GroupLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource FieldBox}"
                                     Text="{Binding DefaultProjectDir}"
                                     IsReadOnly="True" Margin="0,0,8,0"/>
                            <Button Grid.Column="1"
                                    Command="{Binding BrowseDefaultProjectDirCommand}"
                                    Content="Browse…"
                                    Background="#1A3050" Foreground="#00D4FF"
                                    BorderBrush="#2A4060" BorderThickness="1"
                                    Padding="12,7" Cursor="Hand"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding SaveStatus}"
                       Foreground="#2ECC71"
                       VerticalAlignment="Center"
                       FontSize="12"/>

            <Button Grid.Column="1"
                    Content="Cancel"
                    Width="90" Height="34"
                    Margin="0,0,8,0"
                    Background="Transparent"
                    Foreground="#8899AA"
                    BorderBrush="#2A4060" BorderThickness="1"
                    Cursor="Hand"
                    Click="OnCancel"/>

            <Button Grid.Column="2"
                    Content="Save"
                    Width="90" Height="34"
                    Background="#1565C0"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Cursor="Hand"
                    Command="{Binding SaveCommand}"/>
        </Grid>
    </Grid>
</Window>
