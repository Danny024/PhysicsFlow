<UserControl x:Class="PhysicsFlow.App.Views.Forecast.ForecastView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#0A1628">

    <UserControl.Resources>
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#0F2040"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
        </Style>
        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#8899AA"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#CCDDEE"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="ExportButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0F2040"/>
            <Setter Property="Foreground" Value="#00D4FF"/>
            <Setter Property="BorderBrush" Value="#00D4FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Stat cards -->
            <RowDefinition Height="Auto"/>  <!-- Controls -->
            <RowDefinition Height="*"/>     <!-- Charts -->
            <RowDefinition Height="Auto"/>  <!-- Footer / export -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#0F2040" Padding="24,16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="PRODUCTION FORECAST"
                               FontFamily="Segoe UI Semibold" FontSize="20"
                               Foreground="White"/>
                    <TextBlock Text="P10 / P50 / P90 ensemble fan charts with EUR estimates"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#8899AA" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ExportButtonStyle}"
                            Command="{Binding ExportExcelCommand}"
                            Content="⬇  Export Excel" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource ExportButtonStyle}"
                            Command="{Binding ExportPdfCommand}"
                            Content="⬇  Export PDF"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── EUR / Summary stat cards ──────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding EurOilP50, StringFormat={}{0:N1} MMstb}"
                               Style="{StaticResource StatValueStyle}" Foreground="#00CC66"/>
                    <TextBlock Text="EUR Oil P50" Style="{StaticResource StatLabelStyle}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding EurGasP50, StringFormat={}{0:N1} Bscf}"
                               Style="{StaticResource StatValueStyle}" Foreground="#FF8C00"/>
                    <TextBlock Text="EUR Gas P50" Style="{StaticResource StatLabelStyle}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding RecoveryFactorP50, StringFormat={}{0:P1}}"
                               Style="{StaticResource StatValueStyle}"/>
                    <TextBlock Text="Recovery Factor P50" Style="{StaticResource StatLabelStyle}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding PeakOilRateP50, StringFormat={}{0:N0} stb/d}"
                               Style="{StaticResource StatValueStyle}" Foreground="#00CC66"/>
                    <TextBlock Text="Peak Oil Rate P50" Style="{StaticResource StatLabelStyle}"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <TextBlock Text="{Binding ForecastHorizonYears, StringFormat={}{0} years}"
                               Style="{StaticResource StatValueStyle}" Foreground="#8899AA"/>
                    <TextBlock Text="Forecast Horizon" Style="{StaticResource StatLabelStyle}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Control bar ────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#0D1B2E" Padding="16,10" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Well:" Foreground="#8899AA"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding WellNames}"
                          SelectedItem="{Binding SelectedWell}"
                          Width="160" Margin="0,0,24,0"
                          Background="#0F2040" Foreground="White"/>

                <TextBlock Text="Quantity:" Foreground="#8899AA"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding QuantityOptions}"
                          SelectedItem="{Binding SelectedQuantity}"
                          Width="140" Margin="0,0,24,0"
                          Background="#0F2040" Foreground="White"/>

                <TextBlock Text="Horizon:" Foreground="#8899AA"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding HorizonOptions}"
                          SelectedItem="{Binding SelectedHorizon}"
                          Width="100" Margin="0,0,24,0"
                          Background="#0F2040" Foreground="White"/>

                <mah:ToggleSwitch IsOn="{Binding ShowHistoricalData}"
                                  OnContent="History On" OffContent="History Off"
                                  Foreground="White" Margin="0,0,24,0"/>

                <Button Command="{Binding RunForecastCommand}"
                        Content="▶  Run Forecast"
                        Background="#00D4FF" Foreground="#0A1628"
                        FontWeight="Bold" Padding="16,8" Cursor="Hand"
                        BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- ── Charts (2×2 grid) ──────────────────────────────────────────── -->
        <Grid Grid.Row="3" Margin="16,0,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Oil Rate Fan Chart -->
            <Border Grid.Row="0" Grid.Column="0" Background="#0F2040"
                    CornerRadius="8" Margin="0,0,8,8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Oil Production Rate  (stb/day)"
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <oxy:PlotView Grid.Row="1" Model="{Binding OilRatePlotModel}"
                                  Background="Transparent"/>
                </Grid>
            </Border>

            <!-- Water Rate Fan Chart -->
            <Border Grid.Row="0" Grid.Column="1" Background="#0F2040"
                    CornerRadius="8" Margin="0,0,0,8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Water Production Rate  (stb/day)"
                               Style="{StaticResource SectionHeaderStyle}"
                               Foreground="#4488FF"/>
                    <oxy:PlotView Grid.Row="1" Model="{Binding WaterRatePlotModel}"
                                  Background="Transparent"/>
                </Grid>
            </Border>

            <!-- Cumulative Oil (EUR) -->
            <Border Grid.Row="1" Grid.Column="0" Background="#0F2040"
                    CornerRadius="8" Margin="0,0,8,0" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Cumulative Oil Production  (MMstb)"
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <oxy:PlotView Grid.Row="1" Model="{Binding CumOilPlotModel}"
                                  Background="Transparent"/>
                </Grid>
            </Border>

            <!-- Reservoir Pressure -->
            <Border Grid.Row="1" Grid.Column="1" Background="#0F2040"
                    CornerRadius="8" Margin="0" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Average Reservoir Pressure  (bar)"
                               Style="{StaticResource SectionHeaderStyle}"
                               Foreground="#FF6B6B"/>
                    <oxy:PlotView Grid.Row="1" Model="{Binding PressurePlotModel}"
                                  Background="Transparent"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Footer: legend + progress indicator ───────────────────────── -->
        <Border Grid.Row="4" Background="#0D1B2E" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Legend -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Rectangle Width="32" Height="8" Fill="#00CC66" Opacity="0.3" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="P10 (optimistic)" Foreground="#8899AA" FontSize="11" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    <Rectangle Width="32" Height="8" Fill="#00CC66" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="P50 (base case)" Foreground="#8899AA" FontSize="11" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    <Rectangle Width="32" Height="8" Fill="#00CC66" Opacity="0.3" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="P90 (conservative)" Foreground="#8899AA" FontSize="11" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    <Rectangle Width="32" Height="4" Fill="#FFAA00" Margin="0,0,6,0" VerticalAlignment="Center"
                               Visibility="{Binding ShowHistoricalData, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text="Historical data" Foreground="#8899AA" FontSize="11" VerticalAlignment="Center"
                               Visibility="{Binding ShowHistoricalData, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
                <!-- Calculation status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <mah:ProgressRing Width="18" Height="18" Margin="0,0,8,0"
                                       Visibility="{Binding IsCalculating, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#8899AA" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
