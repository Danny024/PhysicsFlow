<mah:MetroWindow x:Class="PhysicsFlow.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:vm="clr-namespace:PhysicsFlow.ViewModels;assembly=PhysicsFlow.ViewModels"
        xmlns:views="clr-namespace:PhysicsFlow.App.Views"
        xmlns:dashboard="clr-namespace:PhysicsFlow.App.Views.Dashboard"
        xmlns:training="clr-namespace:PhysicsFlow.App.Views.Training"
        xmlns:hm="clr-namespace:PhysicsFlow.App.Views.HistoryMatching"
        xmlns:forecast="clr-namespace:PhysicsFlow.App.Views.Forecast"
        xmlns:vis="clr-namespace:PhysicsFlow.App.Views.Visualisation"
        xmlns:ai="clr-namespace:PhysicsFlow.App.Views.AIAssistant"
        Title="PhysicsFlow — AI Reservoir Simulation Platform"
        Height="900" Width="1440"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        TitleBarHeight="36"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        BorderBrush="{DynamicResource MahApps.Brushes.Accent}">

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Image Source="/Resources/logo_small.png" Height="22" Margin="4,0" />
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <mah:MetroWindow.RightWindowCommands>
        <mah:WindowCommands>
            <!-- Engine status indicator -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                <Ellipse Width="8" Height="8" Margin="0,0,4,0"
                         Fill="{Binding EngineStatusColor}" />
                <TextBlock Text="{Binding EngineStatusText}" Foreground="White"
                           FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
        </mah:WindowCommands>
    </mah:MetroWindow.RightWindowCommands>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Navigation sidebar -->
            <ColumnDefinition Width="200" MinWidth="60" MaxWidth="240"/>
            <!-- Main content -->
            <ColumnDefinition Width="*"/>
            <!-- AI Assistant panel (collapsible) -->
            <ColumnDefinition Width="{Binding AssistantPanelWidth}"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  SIDEBAR NAVIGATION                                             -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" Background="{DynamicResource MahApps.Brushes.Gray1}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo / project name -->
            <StackPanel Grid.Row="0" Margin="12,16,12,8">
                <TextBlock Text="PHYSICSFLOW" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource MahApps.Brushes.Accent}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentProjectName}" FontSize="10"
                           Foreground="{DynamicResource MahApps.Brushes.Gray5}"
                           HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <Separator Grid.Row="0" VerticalAlignment="Bottom" Margin="8,0"/>

            <!-- Navigation items -->
            <ListBox Grid.Row="1" ItemsSource="{Binding NavigationItems}"
                     SelectedItem="{Binding SelectedNavItem}"
                     Background="Transparent" BorderThickness="0"
                     Margin="8,8,8,0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding NavigateCommand}"
                                Style="{StaticResource NavButtonStyle}"
                                Margin="0,2">
                            <StackPanel Orientation="Horizontal" Margin="8,10">
                                <ContentControl Content="{Binding Icon}" Width="18" Height="18"
                                                Margin="0,0,10,0"
                                                Foreground="{Binding IsActive, Converter={StaticResource ActiveColorConverter}}"/>
                                <TextBlock Text="{Binding Label}" FontSize="13"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding IsActive, Converter={StaticResource ActiveColorConverter}}"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Bottom: Settings + version -->
            <StackPanel Grid.Row="2" Margin="8,0,8,12">
                <Separator Margin="0,0,0,8"/>
                <Button Content="⚙  Settings" Style="{StaticResource NavButtonStyle}"
                        Command="{Binding OpenSettingsCommand}" Padding="8,8"/>
                <TextBlock Text="v1.2.0" FontSize="9"
                           Foreground="{DynamicResource MahApps.Brushes.Gray6}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  MAIN CONTENT AREA (routed by SelectedNavItem)                 -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}"
                        Margin="0">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                    <dashboard:DashboardView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:TrainingViewModel}">
                    <training:TrainingView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:HistoryMatchingViewModel}">
                    <hm:HistoryMatchingView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:ForecastViewModel}">
                    <forecast:ForecastView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:ReservoirView3DViewModel}">
                    <vis:ReservoirView3D />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:CrossSectionViewModel}">
                    <vis:CrossSectionView />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>

        <!-- GridSplitter between main and AI panel -->
        <GridSplitter Grid.Column="1" HorizontalAlignment="Right"
                      Width="4" Background="{DynamicResource MahApps.Brushes.Gray2}"
                      Visibility="{Binding AssistantPanelVisible, Converter={StaticResource BoolToVisConverter}}"/>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  AI ASSISTANT PANEL                                             -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="2"
              Background="{DynamicResource MahApps.Brushes.Gray1}"
              Visibility="{Binding AssistantPanelVisible, Converter={StaticResource BoolToVisConverter}}">
            <ai:AIAssistantView DataContext="{Binding AIAssistant}"/>
        </Grid>

        <!-- Toggle AI panel button (floating) -->
        <Button Grid.Column="1"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,8,0"
                Command="{Binding ToggleAssistantCommand}"
                ToolTip="Toggle AI Reservoir Assistant"
                Style="{StaticResource FloatingActionButtonStyle}"
                Width="36" Height="36">
            <iconPacks:PackIconMaterial Kind="Robot" Width="16" Height="16"/>
        </Button>
    </Grid>
</mah:MetroWindow>
