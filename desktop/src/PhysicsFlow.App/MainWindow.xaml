<mah:MetroWindow x:Class="PhysicsFlow.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:vm="clr-namespace:PhysicsFlow.ViewModels;assembly=PhysicsFlow.ViewModels"
        xmlns:views="clr-namespace:PhysicsFlow.App.Views"
        xmlns:dashboard="clr-namespace:PhysicsFlow.App.Views.Dashboard"
        xmlns:ps="clr-namespace:PhysicsFlow.App.Views.ProjectSetup"
        xmlns:training="clr-namespace:PhysicsFlow.App.Views.Training"
        xmlns:hm="clr-namespace:PhysicsFlow.App.Views.HistoryMatching"
        xmlns:forecast="clr-namespace:PhysicsFlow.App.Views.Forecast"
        xmlns:vis="clr-namespace:PhysicsFlow.App.Views.Visualisation"
        xmlns:ai="clr-namespace:PhysicsFlow.App.Views.AIAssistant"
        Title="PhysicsFlow — AI Reservoir Simulation Platform"
        Height="900" Width="1440"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        TitleBarHeight="36"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        BorderBrush="{DynamicResource MahApps.Brushes.Accent}">

    <mah:MetroWindow.RightWindowCommands>
        <mah:WindowCommands>
            <!-- Engine status indicator -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                <Ellipse Width="8" Height="8" Margin="0,0,4,0"
                         Fill="{Binding EngineStatusColor}" />
                <TextBlock Text="{Binding EngineStatusText}" Foreground="White"
                           FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
        </mah:WindowCommands>
    </mah:MetroWindow.RightWindowCommands>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Navigation sidebar -->
            <ColumnDefinition Width="200" MinWidth="60" MaxWidth="240"/>
            <!-- Main content -->
            <ColumnDefinition Width="*"/>
            <!-- AI Assistant panel (collapsible) -->
            <ColumnDefinition Width="{Binding AssistantPanelWidth}"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  SIDEBAR NAVIGATION                                             -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" Background="#1A1A2E">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo / project name -->
            <StackPanel Grid.Row="0" Margin="12,16,12,8">
                <TextBlock Text="PHYSICSFLOW" FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource MahApps.Brushes.Accent}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentProjectName}" FontSize="10"
                           Foreground="#7070A0"
                           HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <Separator Grid.Row="0" VerticalAlignment="Bottom" Margin="8,0"/>

            <!-- Navigation items -->
            <StackPanel Grid.Row="1" Margin="8,8,8,0">
                <Button Command="{Binding NavigateToDashboardCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="0,2" Padding="8,10">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="16" Height="16" Margin="0,0,10,0"
                                                    Foreground="#C8C8E0"/>
                        <TextBlock Text="Dashboard" FontSize="13" VerticalAlignment="Center"
                                   Foreground="#C8C8E0"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateToProjectSetupCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="0,2" Padding="8,10">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="FolderOpen" Width="16" Height="16" Margin="0,0,10,0"
                                                    Foreground="#C8C8E0"/>
                        <TextBlock Text="Project" FontSize="13" VerticalAlignment="Center"
                                   Foreground="#C8C8E0"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateToTrainingCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="0,2" Padding="8,10">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Brain" Width="16" Height="16" Margin="0,0,10,0"
                                                    Foreground="#C8C8E0"/>
                        <TextBlock Text="Train PINO" FontSize="13" VerticalAlignment="Center"
                                   Foreground="#C8C8E0"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateToHistoryMatchingCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="0,2" Padding="8,10">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="TuneVariant" Width="16" Height="16" Margin="0,0,10,0"
                                                    Foreground="#C8C8E0"/>
                        <TextBlock Text="History Match" FontSize="13" VerticalAlignment="Center"
                                   Foreground="#C8C8E0"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateToForecastCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="0,2" Padding="8,10">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ChartAreaspline" Width="16" Height="16" Margin="0,0,10,0"
                                                    Foreground="#C8C8E0"/>
                        <TextBlock Text="Forecast" FontSize="13" VerticalAlignment="Center"
                                   Foreground="#C8C8E0"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateTo3DViewerCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="0,2" Padding="8,10">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Cube" Width="16" Height="16" Margin="0,0,10,0"
                                                    Foreground="#C8C8E0"/>
                        <TextBlock Text="3D Viewer" FontSize="13" VerticalAlignment="Center"
                                   Foreground="#C8C8E0"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateToCrossSectionCommand}"
                        Style="{StaticResource NavButtonStyle}" Margin="0,2" Padding="8,10">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="ChartTimelineVariant" Width="16" Height="16" Margin="0,0,10,0"
                                                    Foreground="#C8C8E0"/>
                        <TextBlock Text="Cross Section" FontSize="13" VerticalAlignment="Center"
                                   Foreground="#C8C8E0"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Bottom: Settings + version -->
            <StackPanel Grid.Row="2" Margin="8,0,8,12">
                <Separator Margin="0,0,0,8"/>
                <Button Content="⚙  Settings" Style="{StaticResource NavButtonStyle}"
                        Command="{Binding OpenSettingsCommand}" Padding="8,8"
                        Foreground="#C8C8E0"/>
                <TextBlock Text="v2.0.0" FontSize="9"
                           Foreground="#666688"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  MAIN CONTENT AREA (routed by SelectedNavItem)                 -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}"
                        Margin="0"/>

        <!-- GridSplitter between main and AI panel -->
        <GridSplitter Grid.Column="1" HorizontalAlignment="Right"
                      Width="4" Background="#2A3A50"
                      Visibility="{Binding AssistantPanelVisible, Converter={StaticResource BoolToVisConverter}}"/>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  AI ASSISTANT PANEL                                             -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="2"
              Background="#0F1F35"
              Visibility="{Binding AssistantPanelVisible, Converter={StaticResource BoolToVisConverter}}">
            <ai:AIAssistantView DataContext="{Binding AIAssistant}"/>
        </Grid>

        <!-- Toggle AI panel button (floating) -->
        <Button Grid.Column="1"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,8,8,0"
                Command="{Binding ToggleAssistantCommand}"
                ToolTip="Toggle AI Reservoir Assistant"
                Style="{StaticResource FloatingActionButtonStyle}"
                Width="36" Height="36">
            <iconPacks:PackIconMaterial Kind="Robot" Width="16" Height="16"/>
        </Button>
    </Grid>
</mah:MetroWindow>
