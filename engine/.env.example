# PhysicsFlow Engine v2.0 — Environment Configuration Template
# Copy to .env and edit for your deployment.
#
#   cp .env.example .env
#
# All variables are optional — defaults are production-safe for single-user
# on-premise use.  See engine/physicsflow/config.py for the full list.

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────

# Single-user (SQLite, default):
PHYSICSFLOW_DB_PATH=/data/db/physicsflow.db

# Team (PostgreSQL) — uncomment and fill in for multi-user deployments:
# PHYSICSFLOW_DB_URL=postgresql+psycopg2://physicsflow:changeme@localhost:5432/physicsflow
# PHYSICSFLOW_TEAM_MODE=true

# PostgreSQL container credentials (used by docker-compose.postgres.yml):
POSTGRES_USER=physicsflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=physicsflow

# ─────────────────────────────────────────────────────────────────────────────
# gRPC server
# ─────────────────────────────────────────────────────────────────────────────
PHYSICSFLOW_GRPC_PORT=50051

# ─────────────────────────────────────────────────────────────────────────────
# REST API (v2.0)
# ─────────────────────────────────────────────────────────────────────────────
PHYSICSFLOW_REST_ENABLED=true
PHYSICSFLOW_REST_HOST=0.0.0.0
PHYSICSFLOW_REST_PORT=8000

# API key — leave empty for no auth (LAN single-user mode).
# Set a strong secret for team deployments accessible on the network.
PHYSICSFLOW_REST_API_KEY=

# Comma-separated list of allowed CORS origins (JSON array).
PHYSICSFLOW_REST_CORS_ORIGINS=["http://localhost:8888","http://localhost:3000"]

# ─────────────────────────────────────────────────────────────────────────────
# LLM / AI assistant
# ─────────────────────────────────────────────────────────────────────────────
PHYSICSFLOW_OLLAMA_HOST=http://localhost:11434
PHYSICSFLOW_DEFAULT_LLM_MODEL=llama3.1

# ─────────────────────────────────────────────────────────────────────────────
# Storage paths
# ─────────────────────────────────────────────────────────────────────────────
PHYSICSFLOW_PROJECTS_DIR=/data/projects
PHYSICSFLOW_MODELS_DIR=/data/models

# ─────────────────────────────────────────────────────────────────────────────
# tNavigator bridge (v2.0)
# ─────────────────────────────────────────────────────────────────────────────
# PHYSICSFLOW_TNAVIGATOR_EXE=/opt/tnavigator/bin/tnavigator
# PHYSICSFLOW_TNAVIGATOR_LICENSE_SERVER=27000@license-server

# ─────────────────────────────────────────────────────────────────────────────
# Project encryption
# ─────────────────────────────────────────────────────────────────────────────
# PHYSICSFLOW_ENCRYPTION_KEY=<base64-encoded 32-byte key>
